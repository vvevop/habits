# =================================================
#      Переменные окружения для бэкенда
# =================================================
# Создайте файл .env в корне проекта, скопировав этот,
# и настройте значения для вашего окружения.
# -------------------------------------------------

# --- Настройки сервера ---
# Хост, на котором будет запускаться FastAPI-сервер.
# Для локальной разработки используйте '127.0.0.1' или 'localhost'.
# Для доступа по сети или внутри Docker используйте '0.0.0.0'.
APP_HOST=127.0.0.1

# Порт для FastAPI-сервера.
APP_PORT=8000

# --- Безопасность (CORS) ---
# Разрешенные источники (origins).
# Перечислите через запятую URL-адреса, с которых разрешены запросы к API.
#
# ВАЖНО: Для локальной разработки фронтенда (если вы открываете index.html
# напрямую или через простой файловый сервер), может потребоваться
# добавить 'http://127.0.0.1:8000' или 'http://localhost:8000' (порт,
# на котором работает ваш FastAPI). Если вы используете другой сервер
# для фронтенда (например, Vite dev server на порту 5173), добавьте его URL.
#
# Пример продакшн-окружения: https://your-production-frontend.com
# Пример локальной разработки: http://localhost:3000,http://127.0.0.1:8000
CORS_ORIGINS=https://your-production-frontend.com,http://localhost:3000

# --- База данных ---
# Имя файла базы данных SQLite.
DB_NAME=habits.db

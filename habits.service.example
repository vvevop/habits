[Unit]
Description=Habit Tracker FastAPI Backend Service
After=network.target

[Service]
# Замените 'your_user' на ваше имя пользователя на VPS, от которого будут запускаться файлы
# Например, 'ubuntu' или 'debian'
User=your_user
Group=www-data

# Путь к директории с вашим проектом
WorkingDirectory=/var/www/habits

# Путь к исполняемому файлу uvicorn в вашем виртуальном окружении
ExecStart=/var/www/habits/venv/bin/uvicorn main:app --host localhost --port 8000

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target